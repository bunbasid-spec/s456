<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Tam Ekran Video Oynatıcı -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false" />

    <!-- OSD Kapsayıcı (Alt Bilgi ve Ayar Menüsü) -->
    <LinearLayout
        android:id="@+id/osdContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:background="#D9000000"
        android:padding="20dp"
        android:visibility="gone">

        <!-- Bilgi Bandı (Kanal Simgesi, Adı, Çözünürlük) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/imgChannelLogo"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@android:drawable/ic_media_play"
                android:background="#333333"
                android:padding="4dp"
                android:layout_marginEnd="16dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/imgChannelLogo"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvGroupInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 • Group : TR: ULUSAL"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvChannelTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="28 TR: TRT 1 FHD Ⓗ"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/tvResolution"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1920x1080"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <!-- Sabit EPG Metinleri -->
            <TextView
                android:id="@+id/tvEpgCurrent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/imgChannelLogo"
                android:text="Bilgi Yok"
                android:textColor="#DDDDDD"
                android:textSize="14sp"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvEpgNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="Bilgi Yok"
                android:textColor="#AAAAAA"
                android:textSize="14sp"/>

        </RelativeLayout>

        <!-- İlerleme Çubuğu -->
        <ProgressBar
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:progress="35"
            android:progressTint="#E50914"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"/>

        <!-- Kanal Değiştirme Kılavuz İkonları -->
        <RelativeLayout
            android:id="@+id/layoutNavHints"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⊙ Önceki Kanal"
                android:textColor="#888888"
                android:textSize="12sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Sonraki Kanal ⊙"
                android:textColor="#888888"
                android:textSize="12sp"/>
        </RelativeLayout>

        <!-- OSD Alt Hızlı Ayarlar Menüsü (2. Aşağı Basışta Açılır) -->
        <LinearLayout
            android:id="@+id/osdSettingsMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone">

            <Button
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋\nEpg"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:focusable="true"/>

            <Button
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐\nFavori"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:focusable="true"/>

            <Button
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎬\nFilmler"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:focusable="true"/>

            <Button
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎞️\nSeri"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:focusable="true"/>

            <Button
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍\nArama"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:focusable="true"/>

            <Button
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬\nAltyazı Parçası"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:focusable="true"/>

            <Button
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎵\nSes Parçası"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:focusable="true"/>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
